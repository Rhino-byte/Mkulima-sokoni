# Copy to .env and fill in values. Never commit .env (see repo .gitignore).

DATABASE_URL=

CLOUD_NAME=
API_KEY=
API_SECRET=
CLOUDINARY_URL=

# Firebase — Option B: inline credentials (default for hosting)
# FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
# Use \n for newlines inside the key when single-line in .env
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Optional if Google rejects minimal cert: FIREBASE_PRIVATE_KEY_ID=  FIREBASE_CLIENT_ID=

ADMIN_FIREBASE_UIDS=
DEBUG=False
ENVIRONMENT=development

# Twilio SMS (optional; leave disabled until credentials and templates are ready)
# TWILIO_VERIFICATION_SMS_ENABLED=false
# TWILIO_SUPPORT_SMS_ENABLED=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
# Optional Content API template SIDs (if set, used instead of body text for verify SMS)
# TWILIO_VERIFY_APPROVED_CONTENT_SID=
# TWILIO_VERIFY_REJECTED_CONTENT_SID=
# TWILIO_VERIFY_APPROVED_BODY=
# TWILIO_VERIFY_REJECTED_BODY=
# Base URL for support links in SMS (e.g. https://mkulima-sokoni.vercel.app)
# PUBLIC_APP_URL=
# SUPPORT_TICKET_DEEP_LINK_BASE=
# Phase 2 / deferred: TWILIO_SUPPORT_NOTIFY_NUMBERS (staff SMS on new ticket or user reply)
